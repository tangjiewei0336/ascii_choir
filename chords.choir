\define{Cm6blk}{1/b3/5/6}
\define{Csus2}{1/2/5}
\define{Csus2blk}{1/2/5}
\define{Csus4}{1/4/5}
\define{Csus4blk}{1/4/5}
\define{Cadd9}{1/3/5/2}
\define{Cadd9blk}{1/3/5/2}

// ========== C 调根音和弦（分解）==========
\define{CM_arp}{1 3 5}
\define{Cm_arp}{1 b3 5}
