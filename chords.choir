// 和弦定义头文件 - 在乐谱开头用 import{chords.choir} 引入
// 使用方式：& |1 [CM] 2 [Cm] 3 [G7]|  或  & |1 [CM_arp] 2 [Cm_arp]|
// 根音+和弦：CM/CMblk Cm/Cmblk C7/C7blk #CM bEm 等；_arp=分解，无后缀/blk=块状
// 无根音：M m 7 等为分解；Mblk mblk 为块状；三音和弦已补成四音

// ========== 通用和弦（分解）==========
\define{M}{1 3 5 1}
\define{m}{1 b3 5 1}
\define{5}{1 5 1 5}
\define{dim}{1 b3 b5 1}
\define{aug}{1 3 #5 1}
\define{maj7}{1 3 5 7}
\define{7}{1 3 5 b7}
\define{m7}{1 b3 5 b7}
\define{dim7}{1 b3 b5 6}
\define{m7b5}{1 b3 b5 b7}
\define{6}{1 3 5 6}
\define{m6}{1 b3 5 6}
\define{sus2}{1 2 5 1}
\define{sus4}{1 4 5 1}
\define{add9}{1 3 5 2}

// ========== 通用和弦（块状）==========
\define{Mblk}{1/3/5/1}
\define{mblk}{1/b3/5/1}
\define{5blk}{1/5/1/5}
\define{dimblk}{1/b3/b5/1}
\define{augblk}{1/3/#5/1}
\define{maj7blk}{1/3/5/7}
\define{7blk}{1/3/5/b7}
\define{m7blk}{1/b3/5/b7}
\define{dim7blk}{1/b3/b5/6}
\define{m7b5blk}{1/b3/b5/b7}
\define{6blk}{1/3/5/6}
\define{m6blk}{1/b3/5/6}
\define{sus2blk}{1/2/5/1}
\define{sus4blk}{1/4/5/1}
\define{add9blk}{1/3/5/2}

// ========== C 调根音和弦（块状）==========
\define{CM}{1/3/5}
